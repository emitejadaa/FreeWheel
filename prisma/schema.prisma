generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  DELETED
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  OTHER
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      UserRole   @default(USER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  vehicles Vehicle[]
  listings Listing[]

  @@index([email])
  @@index([status])
}

model Vehicle {
  id           String            @id @default(uuid())
  ownerId      String
  owner        User              @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  brand        String
  model        String
  year         Int
  plate        String?
  color        String?
  seats        Int?
  transmission TransmissionType?
  fuelType     FuelType?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  listings Listing[]

  @@index([ownerId])
  @@index([brand, model])
}

model Listing {
  id           String        @id @default(uuid())
  vehicleId    String
  ownerId      String
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  title        String
  description  String
  pricePerDay  Float
  locationText String
  latitude     Float?
  longitude    Float?
  status       ListingStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ownerId])
  @@index([vehicleId])
  @@index([status, createdAt])
}
