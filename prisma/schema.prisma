generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum VerificationStatus {
  UNVERIFIED
  EMAIL_VERIFIED
  PHONE_VERIFIED
  ID_SUBMITTED
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  DELETED
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  OTHER
}

enum DrivetrainType {
  REAR
  FRONT
  FOUR_BY_FOUR
  AWD
}

enum VerificationCodeTargetType {
  EMAIL
  PHONE
}

enum VerificationCodePurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED_BY_RENTER
  CANCELLED_BY_OWNER
  READY_FOR_PICKUP
  IN_PROGRESS
  RETURN_PENDING
  COMPLETED
  DISPUTED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentRecordStatus {
  MOCK
  PENDING
  PAID
  REFUNDED
  FAILED
  CANCELLED
}

enum MediaAssetKind {
  PROFILE_PHOTO
  VEHICLE_PHOTO
  DOCUMENT
  SELFIE
  LISTING_PHOTO
}

enum MediaAssetStatus {
  PENDING
  ACTIVE
  DELETED
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  password           String
  firstName          String
  lastName           String
  displayName        String?
  phone              String?
  profilePhotoUrl    String?
  role               UserRole           @default(USER)
  status             UserStatus         @default(ACTIVE)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  emailVerifiedAt    DateTime?
  acceptedTermsAt    DateTime?
  googleId           String?   @unique
  acceptedTermsAt    DateTime?
  phoneVerifiedAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  vehicles          Vehicle[]
  listings          Listing[]
  verifications     UserVerification[]
  verificationCodes VerificationCode[]
  bookingsAsOwner   Booking[]          @relation("BookingOwner")
  bookingsAsRenter  Booking[]          @relation("BookingRenter")
  paymentRecords    PaymentRecord[]
  mediaAssets       MediaAsset[]
  auditLogsAsActor  AuditLog[]         @relation("AuditActor")
  auditLogsAsTarget AuditLog[]         @relation("AuditTargetUser")

  @@index([email])
  @@index([status])
  @@index([verificationStatus])
}

model UserVerification {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  status      VerificationStatus @default(ID_SUBMITTED)
  documentUrl String?
  selfieUrl   String?
  notes       String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

model VerificationCode {
  id          String                     @id @default(uuid())
  userId      String
  user        User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  targetType  VerificationCodeTargetType
  targetValue String
  purpose     VerificationCodePurpose @default(EMAIL_VERIFICATION)
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int                        @default(0)
  maxAttempts Int                        @default(5)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([userId, targetType, consumedAt])
  @@index([expiresAt])
}

model Vehicle {
  id                            String            @id @default(uuid())
  ownerId                       String
  owner                         User              @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  brand                         String
  model                         String
  year                          Int
  plate                         String?
  color                         String?
  seats                         Int?
  transmission                  TransmissionType?
  fuelType                      FuelType?
  drivetrain                    DrivetrainType?
  bluetooth                     Boolean?
  rearCamera                    Boolean?
  parkingSensors                Boolean?
  fuelConsumptionLitersPer100Km Float?
  doors                         Int?
  trunkCapacityLiters           Int?
  widthMm                       Int?
  lengthMm                      Int?
  heightMm                      Int?
  weightKg                      Int?
  observations                  String?
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt

  listings Listing[]
  bookings Booking[]

  @@index([ownerId])
  @@index([brand, model])
}

model Listing {
  id                String        @id @default(uuid())
  vehicleId         String
  ownerId           String
  vehicle           Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  owner             User          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  title             String
  description       String
  pricePerDay       Float
  locationText      String
  latitude          Float?
  longitude         Float?
  deliveryLatitude  Float?
  deliveryLongitude Float?
  deliveryRadiusKm  Float?
  status            ListingStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  bookings Booking[]

  @@index([ownerId])
  @@index([vehicleId])
  @@index([status, createdAt])
}

model Booking {
  id                  String        @id @default(uuid())
  listingId           String
  vehicleId           String
  ownerId             String
  renterId            String
  listing             Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  vehicle             Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  owner               User          @relation("BookingOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  renter              User          @relation("BookingRenter", fields: [renterId], references: [id], onDelete: Restrict)
  startDate           DateTime
  endDate             DateTime
  status              BookingStatus @default(REQUESTED)
  pricePerDaySnapshot Float
  totalPriceSnapshot  Float
  currency            String        @default("ARS")
  pickupTokenHash     String?
  returnTokenHash     String?
  pickupTokenPreview  String?
  returnTokenPreview  String?
  pickupConfirmedAt   DateTime?
  returnConfirmedAt   DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  paymentStatus       PaymentStatus @default(NOT_REQUIRED)
  paymentProvider     String?
  providerPaymentId   String?
  platformFeeSnapshot Float?
  depositSnapshot     Float?
  paidAt              DateTime?
  refundedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  paymentRecords PaymentRecord[]

  @@index([listingId])
  @@index([vehicleId])
  @@index([ownerId])
  @@index([renterId])
  @@index([status])
  @@index([startDate, endDate])
}

model PaymentRecord {
  id         String              @id @default(uuid())
  bookingId  String?
  userId     String?
  booking    Booking?            @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user       User?               @relation(fields: [userId], references: [id], onDelete: Restrict)
  status     PaymentRecordStatus @default(MOCK)
  provider   String?
  providerId String?
  amount     Float?
  currency   String              @default("ARS")
  metadata   Json?
  paidAt     DateTime?
  refundedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([bookingId])
  @@index([userId])
  @@index([status])
}

model MediaAsset {
  id              String           @id @default(uuid())
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  entityType      String?
  entityId        String?
  kind            MediaAssetKind
  url             String
  storageProvider String?
  storageKey      String?
  mimeType        String?
  sizeBytes       Int?
  status          MediaAssetStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([ownerId])
  @@index([entityType, entityId])
  @@index([kind])
  @@index([status])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  targetUserId String?
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  targetUser   User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: Restrict)
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}
